# ─────────────────────────────────────────────
#  Application
# ─────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ─────────────────────────────────────────────
#  PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=transactions_db
POSTGRES_USER=txn_user
POSTGRES_PASSWORD=txn_secret_password

# Assembled by the app — do not change the pattern
DATABASE_URL=postgresql://txn_user:txn_secret_password@postgres:5432/transactions_db

# ─────────────────────────────────────────────
#  Redis
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────
#  Celery
# ─────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─────────────────────────────────────────────
#  Google Gemini
# ─────────────────────────────────────────────
# Obtain a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────
#  File upload
# ─────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# ─────────────────────────────────────────────
#  LLM retry settings
# ─────────────────────────────────────────────
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=2.0   # seconds; doubles on each retry
